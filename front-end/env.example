# Local Government Website Configuration
# Copy this file to .env.local and update with your government's information

# Government Information
VITE_GOVERNMENT_NAME="Municipality of Santa Barbara"
VITE_GOVERNMENT_TYPE="Municipality"
VITE_REGION="Ilocos Region"
VITE_PROVINCE="Pangasinan"

# Website Information
VITE_WEBSITE_URL="https://stabarbarapangasinan.gov.ph"
VITE_CONTACT_EMAIL=""
VITE_CONTACT_PHONE=""

# Social Media (Optional)
VITE_FACEBOOK_URL="https://www.facebook.com/santabarbarapangasinan"
VITE_TWITTER_URL="https://twitter.com/your-government"
VITE_INSTAGRAM_URL="https://instagram.com/your-government"
VITE_YOUTUBE_URL="https://youtube.com/your-government"

# SEO
VITE_SITE_DESCRIPTION="BetterGov portal for the Municipality of Santa Barbara, Pangasinan"
VITE_SITE_KEYWORDS="Santa Barbara Pangasinan, local government, municipal services"
VITE_OG_IMAGE_URL=""
VITE_TWITTER_HANDLE=""

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=""
VITE_FACEBOOK_PIXEL_ID=""
